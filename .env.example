# Database Configuration
# PostgreSQL database is stored in ./postgres_data/ directory on the host system
# See MIGRATION_GUIDE.md if migrating from Docker volumes
POSTGRES_PASSWORD=your_secure_postgres_password

# Email Service Configuration
# Set to 'true' to use real SMTP server, 'false' for dummy email service (logs only)
EMAIL_SERVICE_ENABLED=false

# SMTP Server Configuration (used when EMAIL_SERVICE_ENABLED=true)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Authentication Service

# Base URL for email links (e.g., password reset, email verification)
EMAIL_BASE_URL=https://auth.yourdomain.tld

# Frontend API Configuration
# For production, set this to your production API URL (e.g., https://auth.yourdomain.tld)
# For development, it will default to http://localhost:12002
NEXT_PUBLIC_API_URL=https://auth.yourdomain.tld

# Domain Configuration
# Base domain for CORS and cookie settings (without subdomain)
BASE_DOMAIN=yourdomain.tld

# WebAuthn Configuration
# The Relying Party ID for WebAuthn (usually your authentication domain)
WEBAUTHN_RP_ID=auth.yourdomain.tld
# The origin URL for WebAuthn
WEBAUTHN_ORIGIN=https://auth.yourdomain.tld

# Support Configuration
# Support email address for user assistance (used in "Lost 2FA?" link)
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.tld

