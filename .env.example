# Database Configuration
POSTGRES_PASSWORD=your_secure_postgres_password

# Email Service Configuration
# Set to 'true' to use real SMTP server, 'false' for dummy email service (logs only)
EMAIL_SERVICE_ENABLED=false

# SMTP Server Configuration (used when EMAIL_SERVICE_ENABLED=true)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=Authentication Demo

# Base URL for email links (e.g., password reset, email verification)
EMAIL_BASE_URL=https://auth.markpost.dev

# Frontend API Configuration
# For production, set this to your production API URL (e.g., https://auth.markpost.dev)
# For development, it will default to http://localhost:12002
NEXT_PUBLIC_API_URL=https://auth.markpost.dev

